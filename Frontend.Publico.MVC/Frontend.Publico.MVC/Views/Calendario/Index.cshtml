@model List<UTNGOL.Servicios.DTOs.PartidoDTO>

<div class="container py-4">
    <h2 class="text-white mb-4 text-center">
        <i class="bi bi-calendar-event text-warning me-2"></i> Calendario de Partidos
    </h2>

    <div class="row row-cols-1 row-cols-md-2 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var p in Model)
            {
                <div class="col">
                    <div class="card h-100 bg-dark text-white border-warning shadow-sm">
                        <div class="card-header bg-dark border-warning d-flex justify-content-between">
                            <small class="text-warning">@p.FechaHoraUtc.ToString("dd MMM - HH:mm")</small>
                            <span class="badge bg-secondary">@p.Estadio</span>
                        </div>
                        <div class="card-body d-flex align-items-center justify-content-around">
                            <div class="text-center">
                                <h5 class="mb-0">@p.SeleccionLocal</h5>
                            </div>
                            <div class="fs-4 fw-bold text-warning px-3">
                                @if (p.Estado == "Finalizado")
                                {
                                    <span>@p.GolesLocal - @p.GolesVisitante</span>
                                }
                                else
                                {

                                    <span>VS</span>
                                }
                            </div>
                            <div class="text-center">
                                <h5 class="mb-0">@p.SeleccionVisitante</h5>
                            </div>
                        </div>
                        <div class="card-footer bg-dark border-0 text-center">
                            <span class="badge bg-info text-dark">@p.Fase</span>
                            <span class="badge bg-secondary">@p.Grupo</span>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <h4 class="text-white">No hay partidos programados.</h4>
            </div>
        }
    </div>
</div>