@model List<UTNGOL.Servicios.DTOs.PartidoDTO>

<link rel="stylesheet" href="~/css/mundial.css" />

<div class="container-fluid stadium-bg">
    <div class="container">
        <h2 class="title-header">
            <i class="bi bi-trophy-fill text-warning me-2"></i> CALENDARIO MUNDIAL 2026
        </h2>

        <div class="row row-cols-1 row-cols-md-2 g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var p in Model)
                {
                    <div class="col">
                        <div class="card h-100 match-card">
                            <div class="card-header bg-transparent border-0 d-flex justify-content-between pt-3">
                                <span class="badge bg-info text-white">@p.FechaHoraUtc.ToString("dd MMM - HH:mm")</span>
                                <span class="text-muted small"><i class="bi bi-geo-alt"></i> @p.Estadio</span>
                            </div>

                            <div class="card-body d-flex align-items-center justify-content-between px-4">
                                <div class="text-center flex-grow-1">
                                    <h5 class="team-name">@p.SeleccionLocal</h5>
                                </div>

                                <div class="px-3">
                                    @if (p.Estado == "Finalizado")
                                    {
                                        <div class="score-badge fw-bold fs-4">@p.GolesLocal - @p.GolesVisitante</div>
                                    }
                                    else
                                    {
                                        <div class="text-muted fw-bold">VS</div>
                                    }
                                </div>

                                <div class="text-center flex-grow-1">
                                    <h5 class="team-name">@p.SeleccionVisitante</h5>
                                </div>
                            </div>

                            <div class="card-footer bg-transparent border-0 pb-3 text-center">
                                <span class="badge bg-success">@p.Fase</span>
                                <span class="badge bg-warning text-dark">@p.Grupo</span>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <h4 class="text-white">¡Próximamente más partidos emocionantes!</h4>
                </div>
            }
        </div>
    </div>
</div>