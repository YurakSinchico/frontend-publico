@model List<UTNGOL.Servicios.DTOs.PosicionDTO>

<link rel="stylesheet" href="~/css/calendario-estilo.css" />

<div class="container-fluid">
    <h1 class="text-white mb-4"><i class="bi bi-graph-up-arrow"></i> Tabla de Posiciones</h1>

    <div class="calendar-container">
        @if (Model != null && Model.Any())
        {
            <table class="table text-white align-middle">
                <thead>
                    <tr>
                        <th>Selección</th>
                        <th>PJ</th>
                        <th>V</th>
                        <th>E</th>
                        <th>D</th>
                        <th>DG</th>
                        <th>PTS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Nombre</strong> <small class="text-secondary">(@item.CodigoFifa)</small></td>
                            <td>@item.PartidosJugados</td>
                            <td>@item.Victorias</td>
                            <td>@item.Empates</td>
                            <td>@item.Derrotas</td>
                            <td>@item.DiferenciaGoles</td>
                            <td class="text-warning fw-bold">@item.Puntos</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-5">
                <p class="text-white">No hay datos de posiciones disponibles en este momento.</p>
            </div>
        }
    </div>
</div>