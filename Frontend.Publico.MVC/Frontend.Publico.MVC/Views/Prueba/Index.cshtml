@model IEnumerable<UTNGOL.Models.GrupoDTO>

@{
    ViewData["Title"] = "Grupos";
}

<h2>Conexión con Fedora - Test de Grupos</h2>

@if (Model != null && Model.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Código</th>
                <th>Nombre</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var grupo in Model)
            {
                <tr>
                    <td>@grupo.IdGrupo</td>
                    <td>@grupo.Codigo</td>
                    <td>@grupo.Nombre</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-warning">
        No se recibieron datos desde la API de Estadísticas.
    </div>
}