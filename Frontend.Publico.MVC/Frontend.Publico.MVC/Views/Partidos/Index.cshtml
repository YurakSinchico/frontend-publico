@model IEnumerable<UTNGOL.Models.PartidoDTO>

@{
    ViewData["Title"] = "Calendario de Partidos";
}

<div class="container mt-4">

    <h1 class="text-white mb-4">Calendario de Partidos</h1>

    <table class="table table-dark table-hover">

        <thead>
            <tr>
                <th>Fecha</th>
                <th>Fase</th>
                <th>Grupo</th>
                <th>Local</th>
                <th>Visitante</th>
                <th>Acciones</th>
                <th>Marcador</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr class="align-middle">

                    <td class="text-nowrap">

                        @if (item.FechaHoraUtc.HasValue)
                        {
                            var fecha = DateTimeOffset
                                .FromUnixTimeMilliseconds(item.FechaHoraUtc.Value)
                                .LocalDateTime;

                            <span class="text-light">
                                <i class="bi bi-calendar-event me-1"></i>
                                @fecha.ToString("dd MMM")
                                <br />
                                <small class="text-muted">
                                    @fecha.ToString("HH:mm")
                                </small>
                            </span>
                        }
                        else
                        {
                            <span class="text-secondary fst-italic">
                                Sin programar
                            </span>
                        }

                    </td>

                    <td>
                        <span class="badge bg-info text-dark">
                            @(item.Fase ?? "Fase de Grupos")
                        </span>
                    </td>

                    <td>
                        <span class="badge bg-secondary">
                            @(item.Grupo ?? "N/A")
                        </span>
                    </td>

                    <td>
                        <strong>@item.SeleccionLocal</strong>
                    </td>

                    <td>
                        <strong>@item.SeleccionVisitante</strong>
                    </td>

                    <td>

                        <div class="btn-group-vertical">

                            <a asp-action="Details"
                               asp-route-id="@item.IdPartido"
                               class="btn btn-sm btn-info mb-1">
                                Ver
                            </a>

                            @if (User.Identity?.IsAuthenticated == true &&
                                 item.Estado == "PROGRAMADO")
                            {
                                <a asp-controller="Apuesta"
                                   asp-action="Create"
                                   asp-route-id="@item.IdPartido"
                                   class="btn btn-sm btn-success">
                                    Predecir
                                </a>
                            }

                        </div>

                    </td>

                    <td>

                        @if (item.Estado == "FINALIZADO")
                        {
                            <span class="badge bg-success fs-6">
                                @item.GolesLocal - @item.GolesVisitante
                            </span>

                            <div class="text-success small">
                                Finalizado
                            </div>
                        }
                        else if (item.Estado == "PROGRAMADO")
                        {
                            <span class="badge bg-primary fs-6">
                                0 - 0
                            </span>

                            <div class="text-primary small">
                                Por jugar
                            </div>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark fs-6">
                                0 - 0
                            </span>

                            <div class="text-warning small">
                                @item.Estado
                            </div>
                        }

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>