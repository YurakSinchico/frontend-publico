@model IEnumerable<UTNGOL.Models.PartidoDTO>

@{
    ViewData["Title"] = "Calendario Oficial";
}

<link rel="stylesheet" href="~/css/partidos.css" />

<div class="container-fluid py-5">

    <div class="titulo-seccion text-center mb-5">

        <h1>🏆 FIFA WORLD CUP 2026</h1>

        <p>
            Calendario Oficial de Partidos
        </p>

    </div>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            DateTime? fechaLocal = null;
            DateTime fechaUtc = DateTime.UtcNow;

            if (item.FechaHoraUtc.HasValue)
            {
                fechaLocal = DateTimeOffset
                    .FromUnixTimeMilliseconds(item.FechaHoraUtc.Value)
                    .LocalDateTime;

                fechaUtc = DateTimeOffset
                    .FromUnixTimeMilliseconds(item.FechaHoraUtc.Value)
                    .UtcDateTime;
            }

            <div class="col-lg-6">

                <div class="match-card">

                    <div class="fase">
                        @(item.Fase ?? "Fase de Grupos")
                    </div>

                    <div class="equipos">

                        <div class="equipo">
                            <div class="icono">⚽</div>
                            <h3>@item.SeleccionLocal</h3>
                        </div>

                        <div class="vs">
                            VS
                        </div>

                        <div class="equipo">
                            <div class="icono">⚽</div>
                            <h3>@item.SeleccionVisitante</h3>
                        </div>

                    </div>

                    <div class="info">

                        <div>
                            📅 @(fechaLocal?.ToString("dd/MM/yyyy") ?? "-")
                        </div>

                        <div>
                            🕓 @(fechaLocal?.ToString("HH:mm") ?? "-")
                        </div>

                        <div>
                            🏆 Grupo @(item.Grupo ?? "-")
                        </div>

                    </div>

                    <div class="estado">

                        @if (item.Estado == "PROGRAMADO")
                        {
                            <span class="badge bg-success">
                                PROGRAMADO
                            </span>
                        }
                        else if (item.Estado == "FINALIZADO")
                        {
                            <span class="badge bg-danger">
                                FINALIZADO
                            </span>

                            <div class="resultado">
                                @item.GolesLocal - @item.GolesVisitante
                            </div>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">
                                @item.Estado
                            </span>
                        }

                    </div>

                    <div class="acciones">

                        <a asp-action="Details"
                           asp-route-id="@item.IdPartido"
                           class="btn btn-detalle">

                            👁 Ver Partido

                        </a>

                        @if (item.Estado == "PROGRAMADO")
                        {
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a asp-controller="Predicciones"
                                   asp-action="Create"
                                   asp-route-matchId="@item.IdPartido"
                                   asp-route-homeTeam="@item.SeleccionLocal"
                                   asp-route-awayTeam="@item.SeleccionVisitante"
                                   asp-route-matchStartDate="@fechaUtc.ToString("o")"
                                   class="btn btn-prediccion">

                                    🎯 Realizar Predicción

                                </a>
                            }
                            else
                            {
                                <button class="btn btn-login" disabled>

                                    🔒 Inicia sesión para predecir

                                </button>
                            }
                        }
                        else
                        {
                            <button class="btn btn-cerrado" disabled>

                                ⛔ Predicción Cerrada

                            </button>
                        }

                    </div>

                </div>

            </div>
        }

    </div>

</div>