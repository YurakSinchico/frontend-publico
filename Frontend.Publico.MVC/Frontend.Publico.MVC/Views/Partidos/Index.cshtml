@model IEnumerable<UTNGOL.Servicios.DTOs.PartidoDTO>

<h1>Calendario de Partidos</h1>

<table class="table table-dark">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Local</th>
            <th>Visitante</th>
            <th>Marcador</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FechaHoraUtc</td>
                <td>@item.SeleccionLocal</td>
                <td>@item.SeleccionVisitante</td>
                <td>@item.GolesLocal - @item.GolesVisitante</td>
            </tr>
        }
    </tbody>
</table>