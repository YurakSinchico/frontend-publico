@model List<UTNGOL.Servicios.DTOs.PosicionDTO>

@{
    ViewData["Title"] = "Tabla de Posiciones";
}

<link rel="stylesheet" href="~/css/estadisticas.css" />

<div class="container-fluid py-4">
    <div class="text-center mb-5">
        <h1 class="titulo-estadisticas">
            <i class="bi bi-graph-up-arrow text-warning me-2"></i> TABLA DE POSICIONES
        </h1>
        <p class="subtitulo-estadisticas">
            Clasificación general de selecciones • Mundial 2026
        </p>
    </div>

    <div class="tabla-card shadow-sm p-4 mb-5 rounded-4">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Selección</th>
                            <th class="text-center">PJ</th>
                            <th class="text-center">V</th>
                            <th class="text-center">E</th>
                            <th class="text-center">D</th>
                            <th class="text-center">DG</th>
                            <th class="text-center">PTS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>⚽ @item.Nombre</strong>
                                    <small class="text-muted d-block">(@item.CodigoFifa)</small>
                                </td>
                                <td class="text-center">@item.PartidosJugados</td>
                                <td class="text-center">@item.Victorias</td>
                                <td class="text-center">@item.Empates</td>
                                <td class="text-center">@item.Derrotas</td>
                                <td class="text-center">@item.DiferenciaGoles</td>
                                <td class="text-center text-gold fw-bold fs-5">@item.Puntos</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-emoji-frown text-muted fs-1 d-block mb-3"></i>
                <p class="text-muted">No hay datos de posiciones disponibles en este momento.</p>
            </div>
        }
    </div>
</div>