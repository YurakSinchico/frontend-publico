@model IEnumerable<Frontend.Publico.MVC.Controllers.RankingItemViewModel>

@{
    ViewData["Title"] = "Ranking Global";
}

<link rel="stylesheet" href="~/css/billetera.css" />

<div class="container-fluid py-4">

    <!-- HEADER / BREADCRUMB -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light">
        <div class="d-flex align-items-center gap-2 text-muted small">
            <span>Home</span> / <span class="fw-bold text-dark">Ranking Global</span> / <span class="badge bg-info bg-opacity-10 text-cyan rounded-pill">Mundial 2026</span>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="bg-white border rounded-pill px-3 py-1 shadow-sm d-flex align-items-center gap-2">
                <span class="fs-6">🪙</span>
                <span class="small text-muted fw-bold">Saldo:</span>
                <strong class="text-cyan fw-bold">@(ViewBag.GolCoins ?? 10.00) UTNGolCoin</strong>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm rounded-pill px-3 py-1 fw-bold d-flex align-items-center gap-1 text-decoration-none shadow-sm">
                    <i class="bi bi-box-arrow-right"></i> <span class="d-none d-md-inline">Cerrar Sesión</span>
                </a>
            }
        </div>
    </div>

    <!-- TARJETA PRINCIPAL DEL RANKING -->
    <div class="panel-glass-card p-4 p-md-5 rounded-4 shadow-sm bg-white border col-lg-10 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
            <div>
                <h3 class="fw-extrabold text-dark m-0 d-flex align-items-center gap-2 fs-4">
                    🏆 Ranking Global de Participantes
                </h3>
                <small class="text-muted">Tabla de clasificación basada en aciertos y saldo de UTNGolCoins</small>
            </div>
            <span class="badge bg-warning bg-opacity-10 text-warning-emphasis border border-warning border-opacity-25 px-3 py-2 rounded-pill fw-bold">
                🥇 Temporada Mundial 2026
            </span>
        </div>

        <div class="d-flex flex-column gap-3">
            @foreach (var item in Model)
            {
                var isTop1 = item.Rank == 1;
                var isTop2 = item.Rank == 2;
                var isTop3 = item.Rank == 3;
                var displayName = string.IsNullOrEmpty(item.Nombre) ? "Participante" : item.Nombre;
                if (displayName.StartsWith("Usuario #"))
                {
                    displayName = displayName.Replace("Usuario #", "Usuario ");
                }

                <div class="d-flex justify-content-between align-items-center p-3 p-md-4 rounded-4 border transition-all @(isTop1 ? "bg-warning bg-opacity-10 border-warning shadow-sm" : isTop2 ? "bg-light border-secondary border-opacity-25" : isTop3 ? "bg-light border-amber border-opacity-25" : "bg-light border-light")">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rank-badge rounded-circle d-flex align-items-center justify-content-center fw-extrabold fs-5 shadow-sm"
                             style="width: 48px; height: 48px; min-width: 48px; @(isTop1 ? "background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white;" : isTop2 ? "background: linear-gradient(135deg, #94a3b8 0%, #64748b 100%); color: white;" : isTop3 ? "background: linear-gradient(135deg, #b45309 0%, #78350f 100%); color: white;" : "background: #e2e8f0; color: #475569;")">
                            @if (isTop1) { <span>🥇</span> }
                            else if (isTop2) { <span>🥈</span> }
                            else if (isTop3) { <span>🥉</span> }
                            else { <span>#@item.Rank</span> }
                        </div>
                        <div>
                            <h5 class="m-0 fw-bold text-dark fs-6 d-flex align-items-center gap-2">
                                @displayName
                                @if (isTop1)
                                {
                                    <span class="badge bg-warning text-dark rounded-pill small">Líder Absoluto</span>
                                }
                            </h5>
                            <small class="text-muted"><i class="bi bi-bullseye me-1"></i>@item.Aciertos aciertos registrados</small>
                        </div>
                    </div>
                    <div class="text-end">
                        <strong class="text-cyan fs-5 d-block">@item.Saldo.ToString("N2") GolCoins</strong>
                        <small class="text-muted small">Puntaje General</small>
                    </div>
                </div>
            }
        </div>
    </div>

</div>
