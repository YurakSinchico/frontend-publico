@model Frontend.Publico.MVC.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Mi Billetera";
}

<link rel="stylesheet" href="~/css/billetera.css" />

<div class="container py-4">

    <div class="wallet-glass-card mb-4">
        <div class="row align-items-center">
            <div class="col-md-8 mb-3 mb-md-0">
                <div class="d-flex align-items-center gap-3">
                    <div class="wallet-icon-badge">
                        <i class="bi bi-wallet2"></i>
                    </div>
                    <div>
                        <h2 class="fw-extrabold text-white m-0">Mi Billetera UTNGolCoin</h2>
                        <p class="text-muted m-0 small">Consulta tu saldo ficticio académico e historial de transacciones</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-md-end">
                <div class="balance-display-box">
                    <span class="balance-label">SALDO DISPONIBLE</span>
                    <h3 class="balance-amount text-warning">💰 @Model.Wallet?.Balance.ToString("N2")</h3>
                    <span class="balance-unit">UTNGolCoin</span>
                </div>
            </div>
        </div>
    </div>

    <div class="panel-glass-card">
        <h3 class="panel-header-title mb-4">
            <i class="bi bi-journal-text text-cyan"></i> Historial de Transacciones
        </h3>

        @if (!Model.Transactions.Any())
        {
            <div class="empty-state-box text-center py-5">
                <i class="bi bi-receipt fs-1 text-muted d-block mb-2"></i>
                <p class="text-muted m-0">No existen movimientos registrados en tu billetera.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-custom-dark align-middle">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Tipo de Transacción</th>
                            <th>Monto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.Transactions)
                        {
                            <tr>
                                <td>@t.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge-type">@t.Type</span></td>
                                <td>
                                    @if (t.Amount > 0)
                                    {
                                        <span class="text-success fw-bold">+@t.Amount Coins</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">@t.Amount Coins</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>