@model Frontend.Publico.MVC.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Mi Billetera UTNGolCoin";
}

<link rel="stylesheet" href="~/css/billetera.css" />

<div class="container-fluid py-3">

    <!-- HEADER / BREADCRUMB -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light">
        <div class="d-flex align-items-center gap-2 text-muted small">
            <span>Home</span> / <span class="fw-bold text-dark">Mi Billetera</span> / <span class="badge bg-info bg-opacity-10 text-cyan rounded-pill">Mundial 2026</span>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="bg-white border rounded-pill px-3 py-1 shadow-sm d-flex align-items-center gap-2">
                <span class="fs-6">🪙</span>
                <span class="small text-muted fw-bold">Saldo:</span>
                <strong class="text-cyan fw-bold">@Model.Wallet?.Balance.ToString("N2") UTNGolCoin</strong>
            </div>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm rounded-pill px-3 py-1 fw-bold d-flex align-items-center gap-1 text-decoration-none shadow-sm">
                <i class="bi bi-box-arrow-right"></i> <span class="d-none d-md-inline">Cerrar Sesión</span>
            </a>
            <div class="text-white fw-bold d-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 38px; height: 38px; background-color: #06b6d4;">
                U
            </div>
        </div>
    </div>

    <!-- MAIN BILLETERA CONTAINER (SCREENSHOT 5) -->
    <div class="bg-white p-4 p-md-5 rounded-4 border shadow-sm mx-auto col-lg-10">

        <!-- ENCABEZADO -->
        <h3 class="fw-bold text-dark mb-4 d-flex align-items-center gap-2 fs-4">
            <i class="bi bi-wallet2 text-cyan"></i> Mi Billetera UTNGolCoin
        </h3>

        <!-- HEROCARD TEAL DEL SALDO (SCREENSHOT 5) -->
        <div class="p-4 p-md-5 rounded-4 text-white mb-5 shadow-sm d-flex justify-content-between align-items-center"
             style="background: linear-gradient(135deg, #0284c7 0%, #0d9488 100%);">
            <div>
                <small class="text-uppercase fw-bold opacity-75 letter-spacing-1 d-block mb-1">SALDO ACTUAL</small>
                <h1 class="display-4 fw-extrabold m-0">@Model.Wallet?.Balance.ToString("N2") UTNGolCoin</h1>
            </div>
            <div class="d-none d-sm-flex bg-white bg-opacity-20 rounded-4 p-3 fs-1 align-items-center justify-content-center" style="width: 70px; height: 70px;">
                🪙
            </div>
        </div>

        <!-- HISTORIAL DE TRANSACCIONES (LEDGER INMUTABLE) -->
        <h4 class="fw-bold text-dark mb-3 fs-5">Historial de Transacciones (Ledger Inmutable)</h4>

        @if (!Model.Transactions.Any())
        {
            <div class="p-4 rounded-4 border bg-light d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-info bg-opacity-10 text-cyan d-flex align-items-center justify-content-center" style="width: 46px; height: 46px;">
                        🎁
                    </div>
                    <div>
                        <h6 class="m-0 fw-bold text-dark">Bono de Bienvenida</h6>
                        <small class="text-muted">Acreditación automática al registrarse</small>
                    </div>
                </div>
                <div>
                    <strong class="text-cyan fs-5">+10.00 GolCoins</strong>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var t in Model.Transactions)
                {
                    <div class="p-3 p-md-4 rounded-4 border bg-light d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-info bg-opacity-10 text-cyan d-flex align-items-center justify-content-center" style="width: 46px; height: 46px;">
                                @(t.Amount > 0 ? "🎁" : "🎯")
                            </div>
                            <div>
                                <h6 class="m-0 fw-bold text-dark">@t.Type</h6>
                                <small class="text-muted">@t.Date.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        </div>
                        <div>
                            @if (t.Amount > 0)
                            {
                                <strong class="text-cyan fs-5">+@t.Amount.ToString("N2") GolCoins</strong>
                            }
                            else
                            {
                                <strong class="text-danger fs-5">@t.Amount.ToString("N2") GolCoins</strong>
                            }
                        </div>
                    </div>
                }
            </div>
        }

    </div>

</div>
