@model IEnumerable<UTNGOL.Servicios.DTOs.PosicionDTO>

@{
    ViewData["Title"] = "Tabla de Posiciones";
}

<link rel="stylesheet" href="~/css/calendario-estilo.css" />

<div class="container-fluid">
    <h1 class="text-white mb-4"><i class="bi bi-graph-up-arrow"></i> Tabla de Posiciones</h1>

    <div class="calendar-container table-responsive">
        <table class="table table-dark table-hover text-white">
            <thead>
                <tr class="text-secondary">
                    <th>Selección</th>
                    <th class="text-center">PJ</th>
                    <th class="text-center">V</th>
                    <th class="text-center">E</th>
                    <th class="text-center">D</th>
                    <th class="text-center">DG</th>
                    <th class="text-center">PTS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="align-middle">
                        <td>
                            <strong>@item.Nombre</strong>
                            <small class="text-muted">(@item.CodigoFifa)</small>
                        </td>
                        <td class="text-center">@item.PartidosJugados</td>
                        <td class="text-center">@item.Victorias</td>
                        <td class="text-center">@item.Empates</td>
                        <td class="text-center">@item.Derrotas</td>
                        <td class="text-center">@item.DiferenciaGoles</td>
                        <td class="text-center text-warning fw-bold">@item.Puntos</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>