@using System.Security.Claims

@{
    ViewData["Title"] = "Inicio";
}

@if (Context.Request.Query.ContainsKey("error"))
{
    <div class="container mt-3">
        <div class="alert alert-danger shadow text-center">
            @Context.Request.Query["error"]
        </div>
    </div>
}

<div class="gif-hero"></div>
<div class="dark-overlay"></div>

<div class="hero-container">

    <div class="hero-content">

        <img src="~/logos/logo.png" class="hero-logo" />

        <h1>

            FIFA WORLD CUP 2026

        </h1>

        <h2>

            UTN GOL

        </h2>

        <p>

            Vive la emoción del Mundial, consulta resultados, estadísticas,
            grupos y realiza tus predicciones.

        </p>

        @if (!User.Identity.IsAuthenticated)
        {
            <button class="btn-login"
                    data-bs-toggle="modal"
                    data-bs-target="#loginModal">

                Iniciar Sesión

            </button>
        }
        else
        {
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="btn-dashboard">

                Ir a mi Panel

            </a>
        }

    </div>

</div>

<div class="container pb-5">

    <div class="row g-4">

        <div class="col-lg-3 col-md-6">

            <a asp-controller="Partidos"
               asp-action="Index"
               class="text-decoration-none">

                <div class="flash-card">

                    <div class="icono">

                        📅

                    </div>

                    <h3>

                        Calendario

                    </h3>

                    <p>

                        Consulta todos los partidos del Mundial.

                    </p>

                </div>

            </a>

        </div>

        <div class="col-lg-3 col-md-6">

            <a asp-controller="Estadisticas"
               asp-action="Index"
               class="text-decoration-none">

                <div class="flash-card">

                    <div class="icono">

                        📊

                    </div>

                    <h3>

                        Estadísticas

                    </h3>

                    <p>

                        Rendimiento de selecciones y jugadores.

                    </p>

                </div>

            </a>

        </div>

        <div class="col-lg-3 col-md-6">

            <a asp-controller="Selecciones"
               asp-action="Index"
               class="text-decoration-none">

                <div class="flash-card">

                    <div class="icono">

                        ⚽

                    </div>

                    <h3>

                        Selecciones

                    </h3>

                    <p>

                        Conoce todos los equipos participantes.

                    </p>

                </div>

            </a>

        </div>

        <div class="col-lg-3 col-md-6">

            <a asp-controller="Grupos"
               asp-action="Index"
               class="text-decoration-none">

                <div class="flash-card">

                    <div class="icono">

                        🏆

                    </div>

                    <h3>

                        Grupos

                    </h3>

                    <p>

                        Consulta la clasificación oficial.

                    </p>

                </div>

            </a>

        </div>

        @if (User.Identity.IsAuthenticated)
        {

            <div class="col-lg-3 col-md-6">

                <a asp-controller="Dashboard"
                   asp-action="Index"
                   class="text-decoration-none">

                    <div class="flash-card">

                        <div class="icono">

                            ⚡

                        </div>

                        <h3>

                            Mi Panel

                        </h3>

                        <p>

                            Bienvenido @Context.Session.GetString("UserName")

                        </p>

                    </div>

                </a>

            </div>

            <div class="col-lg-3 col-md-6">

                <a asp-controller="Billetera"
                   asp-action="Index"
                   class="text-decoration-none">

                    <div class="flash-card">

                        <div class="icono">

                            💰

                        </div>

                        <h3>

                            GolCoins

                        </h3>

                        <p>

                            Gestiona tu billetera virtual.

                        </p>

                    </div>

                </a>

            </div>

        }

        @if (User.IsInRole("Administrador"))
        {

            <div class="col-lg-3 col-md-6">

                <a asp-controller="Admin"
                   asp-action="Dashboard"
                   class="text-decoration-none">

                    <div class="flash-card admin-card">

                        <div class="icono">

                            ⚙

                        </div>

                        <h3>

                            Administración

                        </h3>

                        <p>

                            Gestión completa del sistema.

                        </p>

                    </div>

                </a>

            </div>

        }

    </div>

</div>