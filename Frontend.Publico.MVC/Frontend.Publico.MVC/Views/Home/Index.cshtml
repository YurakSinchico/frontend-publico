@using System.Security.Claims

@{
    ViewData["Title"] = "Inicio";
}

@if (Context.Request.Query.ContainsKey("error"))
{
    <div class="container mt-3 position-relative z-3">
        <div class="alert alert-danger text-center shadow-lg rounded-4 border-0">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Context.Request.Query["error"]
        </div>
    </div>
}

<div class="gif-hero"></div>
<div class="dark-overlay"></div>

<div class="landing-wrapper">
    <section class="hero-container">
        <div class="hero-content">
            <h3 class="hero-brand">FIFA</h3>
            <h1 class="hero-title">WORLD CUP 2026</h1>
            <div class="hero-subtitle-wrapper">
                <span class="hero-line"></span>
                <span class="hero-subtitle">UNITED BY FOOTBALL • USA - MEX - CAN</span>
                <span class="hero-line"></span>
            </div>
            <p class="hero-description">
                Vive la pasión del torneo más grande del mundo. Consulta el calendario oficial de 104 partidos,<br class="d-none d-md-inline" />
                revisa la tabla de grupos, analiza las estadísticas y gana con tus predicciones 1X2.
            </p>

            @if (!User.Identity?.IsAuthenticated ?? true)
            {
                <button class="btn-login-gold"
                        data-bs-toggle="modal"
                        data-bs-target="#loginModal">
                    <i class="bi bi-person-fill"></i>
                    INICIAR SESIÓN
                </button>
            }
            else
            {
                <a asp-controller="Dashboard"
                   asp-action="Index"
                   class="btn-login-gold text-decoration-none">
                    <i class="bi bi-speedometer2"></i>
                    IR A MI PANEL
                </a>
            }
        </div>
    </section>

    <div class="container cards-home-container">
        <div class="cards-glass-box">
            <div class="row g-4 justify-content-center">
                <div class="col-lg-3 col-md-6">
                    <a asp-controller="Partidos"
                       asp-action="Index"
                       class="text-decoration-none h-100 d-block">
                        <div class="flash-card card-calendario">
                            <div class="icono-box icono-blue">
                                <i class="bi bi-calendar-event"></i>
                            </div>
                            <h3>Calendario</h3>
                            <p>Consulta los 104 partidos del Mundial 2026.</p>
                            <div class="arrow-box arrow-blue">
                                <i class="bi bi-arrow-right"></i>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-lg-3 col-md-6">
                    <a asp-controller="Estadisticas"
                       asp-action="Index"
                       class="text-decoration-none h-100 d-block">
                        <div class="flash-card card-estadisticas">
                            <div class="icono-box icono-green">
                                <i class="bi bi-bar-chart-line"></i>
                            </div>
                            <h3>Estadísticas</h3>
                            <p>Análisis de goles, rendimiento y datos.</p>
                            <div class="arrow-box arrow-green">
                                <i class="bi bi-arrow-right"></i>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-lg-3 col-md-6">
                    <a asp-controller="Selecciones"
                       asp-action="Index"
                       class="text-decoration-none h-100 d-block">
                        <div class="flash-card card-selecciones">
                            <div class="icono-box icono-purple">
                                <i class="bi bi-dribbble"></i>
                            </div>
                            <h3>Selecciones</h3>
                            <p>Conoce las 48 selecciones clasificadas.</p>
                            <div class="arrow-box arrow-purple">
                                <i class="bi bi-arrow-right"></i>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-lg-3 col-md-6">
                    <a asp-controller="Grupos"
                       asp-action="Index"
                       class="text-decoration-none h-100 d-block">
                        <div class="flash-card card-grupos">
                            <div class="icono-box icono-gold">
                                <i class="bi bi-trophy"></i>
                            </div>
                            <h3>Grupos</h3>
                            <p>Tabla de posiciones oficiales de grupos.</p>
                            <div class="arrow-box arrow-gold">
                                <i class="bi bi-arrow-right"></i>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <footer class="home-footer text-center mt-4">
            <p>© 2026 UTN GOL MUNDIAL - Plataforma Oficial de Pronósticos.</p>
        </footer>
    </div>
</div>
