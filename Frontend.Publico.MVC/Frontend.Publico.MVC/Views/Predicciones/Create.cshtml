@model Frontend.Publico.MVC.ViewModels.PredictionViewModel

@{
    ViewData["Title"] = "Realizar Predicción 1X2";
}

<link rel="stylesheet" href="~/css/predicciones.css" />

<div class="container-fluid py-4">

  
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light">
        <div class="d-flex align-items-center gap-2 text-muted small">
            <span>Home</span> / <span class="fw-bold text-dark">Predicciones 1X2</span> / <span class="badge bg-info bg-opacity-10 text-cyan rounded-pill">Mundial 2026</span>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="bg-white border rounded-pill px-3 py-1 shadow-sm d-flex align-items-center gap-2">
                <span class="fs-6">🪙</span>
                <span class="small text-muted fw-bold">Saldo:</span>
                <strong class="text-cyan fw-bold">@Model.WalletBalance.ToString("N2") UTNGolCoin</strong>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm rounded-pill px-3 py-1 fw-bold d-flex align-items-center gap-1 text-decoration-none shadow-sm">
                    <i class="bi bi-box-arrow-right"></i> <span class="d-none d-md-inline">Cerrar Sesión</span>
                </a>
            }
        </div>
    </div>

    <!-- ALERTAS DE BOOTSTRAP PARA NOTIFICACIONES -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-4 text-center mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i> <strong>Operación realizada con éxito:</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-4 text-center mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div id="clientValidationAlert" class="alert alert-warning alert-dismissible fade show shadow-sm border-0 rounded-4 text-center mb-4 d-none" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2 fs-5"></i> <span id="clientValidationText">Monto inválido. Ingrese un número mayor a cero.</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

    <div asp-validation-summary="All" class="alert alert-danger shadow-sm border-0 rounded-4 mb-4" style="display: none;"></div>

    <!-- MAIN FORM CARD -->
    <div class="bg-white p-4 p-md-5 rounded-4 border shadow-sm mx-auto col-lg-10">

        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
            <h3 class="fw-bold text-dark m-0 d-flex align-items-center gap-2 fs-4">
                ✨ Realizar Predicción 1X2
            </h3>
            <span class="badge bg-info bg-opacity-10 text-cyan px-3 py-2 rounded-pill fw-bold">
                Saldo: @Model.WalletBalance.ToString("N2") UTNGolCoin
            </span>
        </div>

        <form asp-action="Create" method="post" id="predictionForm">
            @Html.AntiForgeryToken()

            <input asp-for="MatchId" type="hidden" />
            <input asp-for="MatchStartDate" type="hidden" />
            <input asp-for="HomeTeam" type="hidden" />
            <input asp-for="AwayTeam" type="hidden" />
            <input asp-for="WalletBalance" type="hidden" />
            <input asp-for="AppliedOdds" type="hidden" id="appliedOddsInput" />
            <input asp-for="PredictedResult" type="hidden" id="predictedResultInput" />

            <!-- SELECCIONAR PARTIDO -->
            <div class="mb-4">
                <label class="form-label fw-bold text-dark mb-2">Seleccionar Partido:</label>
                <div class="input-group">
                    <select id="matchSelect" class="form-select py-3 px-3 rounded-3 border-secondary border-opacity-25 bg-light text-dark fw-semibold fs-6" style="appearance: auto;">
                        @if (ViewBag.Partidos != null && ((IEnumerable<UTNGOL.Models.PartidoDTO>)ViewBag.Partidos).Any())
                        {
                            var partidosProgramados = ((IEnumerable<UTNGOL.Models.PartidoDTO>)ViewBag.Partidos)
                                .Where(p => (p.Estado ?? "").Trim().ToUpper() != "FINALIZADO");

                            foreach (var p in partidosProgramados)
                            {
                                bool isSelected = p.IdPartido == Model.MatchId;
                                <option value="@p.IdPartido"
                                        data-home="@p.SeleccionLocal"
                                        data-away="@p.SeleccionVisitante"
                                        data-home-odds="@p.GetHomeOdds().ToString("0.0#")"
                                        data-draw-odds="@p.GetDrawOdds().ToString("0.0#")"
                                        data-away-odds="@p.GetAwayOdds().ToString("0.0#")"
                                        selected="@(isSelected ? "selected" : null)">
                                    @p.SeleccionLocal vs @p.SeleccionVisitante (@(p.Fase ?? "Fase de Grupos"))
                                </option>
                            }
                        }
                        else
                        {
                            <option selected value="@Model.MatchId">@Model.HomeTeam vs @Model.AwayTeam (Estadio Azteca)</option>
                        }
                    </select>
                </div>
            </div>


            <div class="mb-4">
                <label class="form-label fw-bold text-dark mb-2">Pronóstico 1X2:</label>
                <div class="row g-3">
                    <div class="col-md-4">
                        <button type="button" class="btn btn-option-1x2 active w-100 py-3 rounded-3 fw-bold border text-dark d-flex justify-content-center align-items-center" data-val="1" id="btnLocal">
                            Local (<span id="lblOddsLocal">@Model.HomeOdds.ToString("0.0#")x</span>)
                        </button>
                    </div>
                    <div class="col-md-4">
                        <button type="button" class="btn btn-option-1x2 w-100 py-3 rounded-3 fw-bold border text-dark d-flex justify-content-center align-items-center" data-val="X" id="btnEmpate">
                            Empate (<span id="lblOddsDraw">@Model.DrawOdds.ToString("0.0#")x</span>)
                        </button>
                    </div>
                    <div class="col-md-4">
                        <button type="button" class="btn btn-option-1x2 w-100 py-3 rounded-3 fw-bold border text-dark d-flex justify-content-center align-items-center" data-val="2" id="btnVisitante">
                            Visitante (<span id="lblOddsAway">@Model.AwayOdds.ToString("0.0#")x</span>)
                        </button>
                    </div>
                </div>
                <span asp-validation-for="PredictedResult" class="text-danger small mt-1 d-block"></span>
            </div>

      
            <div class="mb-4">
                <label class="form-label fw-bold text-dark mb-2">Monto a apostar (UTNGolCoin):</label>
                <input asp-for="Amount"
                       id="amountInput"
                       type="number"
                       step="1"
                       min="1"
                       max="@Model.WalletBalance"
                       class="form-control py-3 px-3 rounded-3 border-secondary border-opacity-25 text-dark fw-semibold fs-6"
                       value="2"
                       required />
                <span asp-validation-for="Amount" class="text-danger small mt-1 d-block"></span>
                <small class="text-muted mt-1 d-block">
                    <i class="bi bi-info-circle me-1"></i> El monto debe ser mayor a 0 y no exceder tu saldo disponible (@Model.WalletBalance.ToString("N2") Coins).
                </small>
            </div>


            <div class="mt-4">
                <button type="submit" class="btn text-white w-100 py-3 fw-bold fs-6 rounded-3 shadow-sm d-flex justify-content-center align-items-center gap-2" style="background: linear-gradient(135deg, #06b6d4 0%, #0d9488 100%);">
                    <i class="bi bi-check-circle-fill fs-5"></i> Confirmar Predicción
                </button>
            </div>

        </form>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const buttons = document.querySelectorAll(".btn-option-1x2");
        const hiddenInput = document.getElementById("predictedResultInput");
        const appliedOddsInput = document.getElementById("appliedOddsInput");
        const matchSelect = document.getElementById("matchSelect");
        const matchIdInput = document.querySelector('input[name="MatchId"]');
        const homeTeamInput = document.querySelector('input[name="HomeTeam"]');
        const awayTeamInput = document.querySelector('input[name="AwayTeam"]');
        const amountInput = document.getElementById("amountInput");
        const predictionForm = document.getElementById("predictionForm");
        const alertBox = document.getElementById("clientValidationAlert");
        const alertText = document.getElementById("clientValidationText");

        const lblOddsLocal = document.getElementById("lblOddsLocal");
        const lblOddsDraw = document.getElementById("lblOddsDraw");
        const lblOddsAway = document.getElementById("lblOddsAway");

   
        let currentOdds = { '1': 1.8, 'X': 3.2, '2': 2.5 };

        hiddenInput.value = "1";

        function updateOddsFromSelectedOption() {
            if (!matchSelect) return;
            const opt = matchSelect.options[matchSelect.selectedIndex];
            if (opt) {
                const id = opt.value;
                const home = opt.getAttribute("data-home") || "Local";
                const away = opt.getAttribute("data-away") || "Visitante";
                const hOdds = opt.getAttribute("data-home-odds") || "1.8";
                const dOdds = opt.getAttribute("data-draw-odds") || "3.2";
                const aOdds = opt.getAttribute("data-away-odds") || "2.5";

                if (matchIdInput) matchIdInput.value = id;
                if (homeTeamInput) homeTeamInput.value = home;
                if (awayTeamInput) awayTeamInput.value = away;

                if (lblOddsLocal) lblOddsLocal.innerText = hOdds + "x";
                if (lblOddsDraw) lblOddsDraw.innerText = dOdds + "x";
                if (lblOddsAway) lblOddsAway.innerText = aOdds + "x";

                currentOdds['1'] = hOdds.replace(',', '.');
                currentOdds['X'] = dOdds.replace(',', '.');
                currentOdds['2'] = aOdds.replace(',', '.');

                if (appliedOddsInput) appliedOddsInput.value = currentOdds[hiddenInput.value];
            }
        }

        if (matchSelect) {
            matchSelect.addEventListener("change", updateOddsFromSelectedOption);
            updateOddsFromSelectedOption();
        }

        buttons.forEach(btn => {
            btn.addEventListener("click", function () {
                buttons.forEach(b => {
                    b.classList.remove("active");
                    b.style.backgroundColor = "#ffffff";
                    b.style.borderColor = "#dee2e6";
                    b.style.color = "#0f172a";
                });

                this.classList.add("active");
                this.style.backgroundColor = "#e0f2fe";
                this.style.borderColor = "#06b6d4";
                this.style.color = "#0891b2";

                hiddenInput.value = this.getAttribute("data-val");
                if (appliedOddsInput) appliedOddsInput.value = currentOdds[hiddenInput.value];
            });
        });

 
        if (amountInput) {
            amountInput.addEventListener("keydown", function (e) {
                if (e.key === "-" || e.key === "+" || e.key === "e" || e.key === "E") {
                    e.preventDefault();
                }
            });
        }

        if (predictionForm) {
            predictionForm.addEventListener("submit", function (e) {
                const val = parseFloat(amountInput.value);
                if (isNaN(val) || val <= 0) {
                    e.preventDefault();
                    if (alertBox && alertText) {
                        alertText.innerText = "Error: El monto a apostar debe ser mayor a 0 y no puede contener símbolos ni letras.";
                        alertBox.classList.remove("d-none");
                    }
                    amountInput.focus();
                }
            });
        }
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

