@model Frontend.Publico.MVC.ViewModels.PredictionViewModel

@{
    ViewData["Title"] = "Nueva Predicción";
}

<link rel="stylesheet" href="~/css/predicciones.css" />

<div class="container py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-lg border-0 rounded-4 text-center mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <div asp-validation-summary="All" class="alert alert-danger shadow-lg border-0 rounded-4 mb-4" style="display: none;"></div>

    <div class="prediction-card mx-auto">

        <!-- Encabezado -->
        <div class="text-center mb-4">
            <div class="predict-badge mx-auto mb-2">
                <i class="bi bi-bullseye"></i>
            </div>
            <h2 class="fw-extrabold text-white mb-1">REALIZAR PREDICCIÓN</h2>
            <p class="text-muted small">Selecciona tu pronóstico 1X2 e ingresa el monto en GolCoins</p>
        </div>

        <!-- Enfrentamiento -->
        <div class="match-box p-4 rounded-4 mb-4">
            <div class="team text-center">
                <div class="team-icon mb-2">⚽</div>
                <h4 class="fw-bold text-white m-0">@Model.HomeTeam</h4>
                <small class="text-cyan">LOCAL</small>
            </div>

            <div class="vs-badge">
                VS
            </div>

            <div class="team text-center">
                <div class="team-icon mb-2">⚽</div>
                <h4 class="fw-bold text-white m-0">@Model.AwayTeam</h4>
                <small class="text-cyan">VISITANTE</small>
            </div>
        </div>

        <!-- Saldo Disponible -->
        <div class="wallet-badge-box text-center p-3 rounded-4 mb-4">
            <span class="text-muted text-uppercase fw-bold fs-7">SALDO DISPONIBLE:</span>
            <span class="text-warning fw-extrabold fs-5 ms-2">💰 @Model.WalletBalance UTNGolCoin</span>
        </div>

        <!-- Formulario -->
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <input asp-for="MatchId" type="hidden" />
            <input asp-for="MatchStartDate" type="hidden" />
            <input asp-for="HomeTeam" type="hidden" />
            <input asp-for="AwayTeam" type="hidden" />
            <input asp-for="WalletBalance" type="hidden" />

            <div class="mb-4">
                <label class="form-label text-cyan fw-bold fs-7 mb-2">
                    <i class="bi bi-trophy me-1"></i> PRONÓSTICO (RESULTADO ESPERADO)
                </label>
                <select asp-for="PredictedResult" class="form-select predict-input">
                    <option value="">Seleccione un resultado...</option>
                    <option value="1">1 - Gana @Model.HomeTeam (Local)</option>
                    <option value="X">X - Empate</option>
                    <option value="2">2 - Gana @Model.AwayTeam (Visitante)</option>
                </select>
                <span asp-validation-for="PredictedResult" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label text-cyan fw-bold fs-7 mb-2">
                    <i class="bi bi-coin me-1"></i> CANTIDAD DE GOLCOINS A APOSTAR
                </label>
                <input asp-for="Amount"
                       type="number"
                       step="1"
                       min="1"
                       max="@Model.WalletBalance"
                       class="form-control predict-input"
                       placeholder="Ej. 5"
                       required />
                <span asp-validation-for="Amount" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-predict-submit w-100 fw-bold py-3 mt-2">
                <i class="bi bi-check2-circle me-2"></i> CONFIRMAR PREDICCIÓN
            </button>
        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}