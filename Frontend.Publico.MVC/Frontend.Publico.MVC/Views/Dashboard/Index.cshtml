@model Frontend.Publico.MVC.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Mi Panel";
}

<link rel="stylesheet" href="~/css/dashboard-premium.css" />


<div class="container-fluid py-4">


    <!-- CABECERA -->
    <div class="hero-dashboard">

        <div class="hero-text">

            <h1>
                👋 ¡Bienvenido, @User.Identity!.Name!
            </h1>

            <p>
                Vive la emoción del Mundial FIFA 2026 y administra tus predicciones desde un solo lugar.
            </p>

        </div>

    </div>



    <!-- TARJETAS -->
    <div class="row g-4 mt-2">


        <!-- SALDO -->
        <div class="col-xl-3 col-md-6">

            <div class="stat-card balance">


                <div class="icono">
                    💰
                </div>


                <h6>
                    Saldo Disponible
                </h6>


                <h2>
                    @Model.Wallet?.Balance.ToString("N2")
                </h2>


                <span>
                    UTNGolCoin
                </span>


                <!-- PRUEBA WALLET -->
                <hr />

                <div style="font-size:18px; margin-top:10px;">

                    🪙 GolCoins desde ViewBag:

                    <strong>
                        @ViewBag.GolCoins
                    </strong>

                </div>


            </div>

        </div>



        <!-- TOTAL PREDICCIONES -->
        <div class="col-xl-3 col-md-6">

            <div class="stat-card">


                <div class="icono">
                    🎯
                </div>


                <h6>
                    Total Predicciones
                </h6>


                <h2>
                    @Model.TotalPredictions
                </h2>


            </div>

        </div>




        <!-- GANADAS -->
        <div class="col-xl-2 col-md-4">

            <div class="stat-card success">


                <div class="icono">
                    🟢
                </div>


                <h6>
                    Ganadas
                </h6>


                <h2>
                    @Model.WonPredictions
                </h2>


            </div>

        </div>





        <!-- PENDIENTES -->
        <div class="col-xl-2 col-md-4">

            <div class="stat-card warning">


                <div class="icono">
                    🟡
                </div>


                <h6>
                    Pendientes
                </h6>


                <h2>
                    @Model.PendingPredictions
                </h2>


            </div>

        </div>





        <!-- PERDIDAS -->
        <div class="col-xl-2 col-md-4">

            <div class="stat-card danger">


                <div class="icono">
                    🔴
                </div>


                <h6>
                    Perdidas
                </h6>


                <h2>
                    @Model.LostPredictions
                </h2>


            </div>

        </div>


    </div>






    <!-- DOS COLUMNAS -->

    <div class="row mt-5">



        <!-- PREDICCIONES -->

        <div class="col-lg-7">


            <div class="panel-card">


                <h3 class="mb-4">
                    🎯 Últimas Predicciones
                </h3>



                @if (Model.Predictions.Any())
                {


                    <table class="table table-dark table-hover align-middle">


                        <thead>


                            <tr>

                                <th>
                                    Partido
                                </th>


                                <th>
                                    Resultado
                                </th>


                                <th>
                                    Monto
                                </th>


                                <th>
                                    Estado
                                </th>


                            </tr>


                        </thead>



                        <tbody>



                            @foreach (var p in Model.Predictions.Take(5))
                            {


                                <tr>


                                    <td>
                                        #@p.MatchId
                                    </td>


                                    <td>
                                        @p.PredictedResult
                                    </td>


                                    <td>
                                        @p.Amount Coins
                                    </td>


                                    <td>


                                        @if (p.Status == "Ganada")
                                        {

                                            <span class="badge bg-success">
                                                Ganada
                                            </span>

                                        }
                                        else if (p.Status == "Perdida")
                                        {

                                            <span class="badge bg-danger">
                                                Perdida
                                            </span>

                                        }
                                        else
                                        {

                                            <span class="badge bg-warning text-dark">
                                                Pendiente
                                            </span>

                                        }


                                    </td>


                                </tr>


                            }



                        </tbody>


                    </table>


                }
                else
                {


                    <div class="empty-box">

                        Aún no has realizado ninguna predicción.

                    </div>


                }



            </div>


        </div>






        <!-- MOVIMIENTOS -->


        <div class="col-lg-5">


            <div class="panel-card">



                <h3 class="mb-4">

                    💳 Últimos Movimientos

                </h3>





                @if (Model.Transactions.Any())
                {


                    <table class="table table-dark align-middle">


                        <thead>


                            <tr>

                                <th>
                                    Fecha
                                </th>


                                <th>
                                    Tipo
                                </th>


                                <th>
                                    Monto
                                </th>


                            </tr>


                        </thead>



                        <tbody>



                            @foreach (var t in Model.Transactions.Take(5))
                            {


                                <tr>


                                    <td>
                                        @t.Date.ToString("dd/MM")
                                    </td>


                                    <td>
                                        @t.Type
                                    </td>


                                    <td>


                                        @if (t.Amount > 0)
                                        {

                                            <span class="text-success fw-bold">
                                                +@t.Amount
                                            </span>

                                        }
                                        else
                                        {

                                            <span class="text-danger fw-bold">
                                                @t.Amount
                                            </span>

                                        }


                                    </td>


                                </tr>


                            }



                        </tbody>


                    </table>


                }
                else
                {


                    <div class="empty-box">

                        No existen movimientos registrados.

                    </div>


                }




            </div>


        </div>



    </div>



</div>