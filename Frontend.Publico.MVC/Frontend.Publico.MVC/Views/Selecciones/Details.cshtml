@model UTNGOL.Models.SeleccionDTO

@{
    ViewData["Title"] = Model.Nombre;
}

<link rel="stylesheet" href="~/css/selecciones.css" />

<div class="container-fluid py-4">

    <div class="bg-white p-4 p-md-5 rounded-4 border shadow-sm mx-auto col-lg-8 text-center">

        <div class="rounded-circle bg-info bg-opacity-10 text-cyan d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
            <span class="fs-1">⚽</span>
        </div>

        <h1 class="fw-extrabold text-dark mb-2 fs-2">
            @Model.Nombre
        </h1>
        <p class="text-muted mb-4">Detalles oficiales de la selección clasificada</p>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="bg-light p-4 rounded-4 border">
                    <span class="text-muted small fw-bold text-uppercase d-block mb-1">Código FIFA</span>
                    <h4 class="fw-bold text-dark m-0">@Model.CodigoFifa</h4>
                </div>
            </div>

            <div class="col-md-4">
                <div class="bg-light p-4 rounded-4 border">
                    <span class="text-muted small fw-bold text-uppercase d-block mb-1">Grupo</span>
                    <h4 class="fw-bold text-cyan m-0">Grupo @(Model.Grupo ?? "-")</h4>
                </div>
            </div>

            <div class="col-md-4">
                <div class="bg-light p-4 rounded-4 border">
                    <span class="text-muted small fw-bold text-uppercase d-block mb-1">Confederación</span>
                    <h4 class="fw-bold text-primary m-0">@(Model.Confederacion ?? "FIFA")</h4>
                </div>
            </div>
        </div>

        <div>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold text-decoration-none">
                ← Volver a Selecciones
            </a>
        </div>

    </div>

</div>