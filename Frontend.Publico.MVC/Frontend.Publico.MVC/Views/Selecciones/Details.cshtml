@model UTNGOL.Models.SeleccionDTO

@{
    ViewData["Title"] = Model.Nombre;
}

<link rel="stylesheet" href="~/css/selecciones.css" />

<div class="container py-5">

    <div class="detalle-seleccion">

        <div class="text-center">

            <div class="team-icon">

                ⚽

            </div>

            <h1>

                @Model.Nombre

            </h1>

        </div>

        <div class="row mt-5">

            <div class="col-md-4">

                <div class="info-box">

                    <h5>

                        Código FIFA

                    </h5>

                    <p>

                        @Model.CodigoFifa

                    </p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="info-box">

                    <h5>

                        Grupo

                    </h5>

                    <p>

                        @Model.Grupo

                    </p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="info-box">

                    <h5>

                        Confederación

                    </h5>

                    <p>

                        @Model.Confederacion

                    </p>

                </div>

            </div>

        </div>

        <div class="text-center mt-5">

            <a asp-action="Index"
               class="btn btn-outline-light btn-lg">

                ← Volver

            </a>

        </div>

    </div>

</div>