@model IEnumerable<UTNGOL.Servicios.DTOs.SeleccionDTO>

<h1>Selecciones Disponibles</h1>

<table class="table">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Código FIFA</th>
            <th>Grupo</th>
            <th>Acciones</th> <!-- Nueva columna -->
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.CodigoFifa</td>
                <td>@item.Grupo</td>
                <td>
                    <!-- Este es el enlace que envía el código al controlador -->
                    <a asp-action="Details" asp-route-id="@item.CodigoFifa" class="btn btn-info btn-sm">
                        Ver Detalle
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>