@model IEnumerable<UTNGOL.Models.SeleccionDTO>

@{
    ViewData["Title"] = "Selecciones";
}

<link rel="stylesheet" href="~/css/selecciones.css" />

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="titulo-selecciones">

            🌍 SELECCIONES CLASIFICADAS

        </h1>

        <p class="subtitulo-selecciones">

            FIFA WORLD CUP 2026

        </p>

    </div>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-6">

                <div class="team-card">

                    <div class="team-icon">

                        ⚽

                    </div>

                    <h3>

                        @item.Nombre

                    </h3>

                    <hr />

                    <p>

                        <strong>Código FIFA</strong>

                        <br />

                        @item.CodigoFifa

                    </p>

                    <p>

                        <strong>Grupo</strong>

                        <br />

                        @item.Grupo

                    </p>

                    <p>

                        <strong>Confederación</strong>

                        <br />

                        @item.Confederacion

                    </p>

                    <a asp-action="Details"
                       asp-route-id="@item.IdSeleccion"
                       class="btn btn-warning w-100">

                        👁 Ver Detalles

                    </a>

                </div>

            </div>
        }

    </div>

</div>