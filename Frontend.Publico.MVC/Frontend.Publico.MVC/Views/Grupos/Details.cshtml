@model IEnumerable<UTNGOL.Models.SeleccionDTO>

@{
    var grupoKey = ViewBag.GrupoKey as string ?? "A";
    ViewData["Title"] = $"Detalle Grupo {grupoKey}";
}

<link rel="stylesheet" href="~/css/grupos.css" />

<div class="container-fluid py-4">

   
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light">
        <div class="d-flex align-items-center gap-2 text-muted small">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Home</a> / 
            <a asp-controller="Grupos" asp-action="Index" class="text-decoration-none text-muted">Grupos</a> / 
            <span class="fw-bold text-dark">Grupo @grupoKey</span>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3 py-1 fw-bold text-decoration-none">
                ← Volver a Grupos
            </a>
        </div>
    </div>


    <div class="bg-white p-4 p-md-5 rounded-4 border shadow-sm mx-auto col-lg-10">

        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
            <div>
                <h3 class="fw-extrabold text-dark m-0 d-flex align-items-center gap-2 fs-3">
                    🏆 Clasificación Oficial • Grupo @grupoKey
                </h3>
                <small class="text-muted">FIFA World Cup 2026</small>
            </div>
            <span class="badge bg-cyan text-white fs-6 px-3 py-2 rounded-pill fw-bold">
                Grupo @grupoKey
            </span>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle m-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Selección</th>
                            <th class="text-center">Código FIFA</th>
                            <th class="text-center">PJ</th>
                            <th class="text-center">Confederación</th>
                            <th class="text-end">Puntos</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int pos = 1; }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-muted">@pos</td>
                                <td>
                                    <strong class="text-dark fs-6">⚽ @item.Nombre</strong>
                                </td>
                                <td class="text-center text-muted small fw-bold">
                                    @item.CodigoFifa
                                </td>
                                <td class="text-center fw-semibold">
                                    @item.PartidosJugados
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border px-3 py-1 rounded-pill small">
                                        @(item.Confederacion ?? "FIFA")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <span class="badge bg-cyan text-white fs-6 px-3 py-1 rounded-pill fw-extrabold">
                                        @item.Puntos pts
                                    </span>
                                </td>
                            </tr>
                            pos++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted fs-1 d-block mb-3"></i>
                <h5 class="fw-bold text-dark">Sin datos disponibles para este grupo</h5>
                <p class="text-muted small">No se encontraron selecciones registradas para el Grupo @grupoKey.</p>
            </div>
        }

        <div class="mt-4 text-center">
            <a asp-action="Index" class="btn btn-outline-cyan rounded-pill px-4 py-2 fw-bold text-decoration-none">
                ← Volver a Grupos
            </a>
        </div>

    </div>

</div>
