@model IEnumerable<IGrouping<string, UTNGOL.Models.SeleccionDTO>>

@{
    ViewData["Title"] = "Grupos";
}

<link rel="stylesheet" href="~/css/grupos.css" />

<div class="container-fluid py-4">

    <div class="text-center mb-5">
        <h1 class="fw-extrabold text-dark mb-2 fs-2">
            🏆 FASE DE GRUPOS
        </h1>
        <p class="text-muted">
            FIFA WORLD CUP 2026 • Clasificación Oficial por Grupos
        </p>
    </div>

    <div class="row g-4">
        @foreach (var grupo in Model)
        {
            <div class="col-lg-6 mb-2">
                <div class="bg-white rounded-4 border shadow-sm overflow-hidden h-100 hover-shadow transition-all">
                    <div class="p-3 px-4 text-white d-flex justify-content-between align-items-center"
                         style="background: linear-gradient(135deg, #0284c7 0%, #06b6d4 100%);">
                        <h4 class="m-0 fw-extrabold fs-5">Grupo @grupo.Key</h4>
                        <span class="badge bg-white bg-opacity-20 text-white rounded-pill px-3 py-1 small fw-bold">4 Selecciones</span>
                    </div>

                    <div class="table-responsive p-3">
                        <table class="table align-middle m-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Selección</th>
                                    <th class="text-center">Código</th>
                                    <th class="text-center">PJ</th>
                                    <th class="text-end">Puntos</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in grupo.OrderByDescending(x => x.Puntos))
                                {
                                    <tr>
                                        <td>
                                            <strong class="text-dark">⚽ @item.Nombre</strong>
                                        </td>
                                        <td class="text-center text-muted small fw-bold">
                                            @item.CodigoFifa
                                        </td>
                                        <td class="text-center text-secondary small">
                                            @item.PartidosJugados
                                        </td>
                                        <td class="text-end">
                                            <span class="badge bg-cyan text-white fs-6 px-3 py-1 rounded-pill fw-bold">
                                                @item.Puntos pts
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="p-3 bg-light border-top text-center">
                        <a asp-action="Details" asp-route-id="@grupo.Key" class="btn btn-outline-cyan btn-sm rounded-pill px-4 fw-bold text-decoration-none">
                            👁 Ver Detalle Grupo @grupo.Key
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

</div>