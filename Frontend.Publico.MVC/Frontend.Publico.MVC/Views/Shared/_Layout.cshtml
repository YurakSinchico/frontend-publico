<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UTN GOL MUNDIAL</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/sidebar-moderna.css" />
    <link rel="stylesheet" href="~/css/home-estilos.css" />
    <link rel="stylesheet" href="~/css/login-modal.css" />
</head>
<body>

    <!-- El Sidebar físico solo se muestra si está logueado -->
    @if (User.Identity.IsAuthenticated)
    {
        <div class="sidebar">
            <partial name="_Sidebar" />
        </div>
    }

    <!-- Contenedor adaptativo -->
    <main class="main-content-wrapper @(!User.Identity.IsAuthenticated ? "main-content-full" : "")">
        @RenderBody()
    </main>

    <!-- Modal de Login -->
    <div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-content-ecumex">
                <div class="modal-header border-0 pb-0 bg-dark text-white">
                    <div class="w-100 text-center"><div class="fs-1">⚡</div><h4 class="fw-bold">UTN GOL MUNDIAL</h4></div>
                </div>
                <div class="modal-body bg-dark text-white">
                    <form asp-controller="Account" asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3"><label class="form-label text-warning fw-semibold">CORREO</label><input type="email" name="Email" class="form-control" required /></div>
                        <div class="mb-3"><label class="form-label text-warning fw-semibold">CONTRASEÑA</label><input type="password" name="Password" class="form-control" required /></div>
                        <button type="submit" class="btn btn-primary w-100 fw-bold py-2 mt-2">INGRESAR</button>
                    </form>
                </div>
                <
                    <link href="c:\users\hp\documents\3_semestre\herramientas\proyectos\frontend-publico\frontend.publico.mvc\frontend.publico.mvc\views\shared\_layout.cshtml.css" rel="stylesheet" />
                    <a href="c:\users\hp\documents\3_semestre\herramientas\proyectos\frontend-publico\frontend.publico.mvc\frontend.publico.mvc\views\shared\_layout.cshtml">c:\users\hp\documents\3_semestre\herramientas\proyectos\frontend-publico\frontend.publico.mvc\frontend.publico.mvc\views\shared\_layout.cshtml</a>/div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @if (ViewBag.Error != null)
    {
        <script>document.addEventListener("DOMContentLoaded", function() { new bootstrap.Modal(document.getElementById('loginModal')).show(); });</script>
    }
</body>
</html>