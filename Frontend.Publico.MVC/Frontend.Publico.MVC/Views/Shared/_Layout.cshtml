<!DOCTYPE html>
<html lang="es">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/sidebar-moderna.css" />
    <link rel="stylesheet" href="~/css/home-estilos.css" />
    <link rel="stylesheet" href="~/css/login-modal.css" />
</head>
<body>
    <partial name="_Sidebar" />

    <main class="main-content-wrapper">
        @RenderBody()
    </main>

    <!-- Modal de Login Original -->
    <div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-content-ecumex">
                <div class="modal-header modal-header-ecumex">
                    <div class="w-100">
                        <!-- Aquí va tu gif/icono original -->
                        <div class="icon-ecumex">⚡</div>
                        <h4 class="title-ecumex">UTN GOL MUNDIAL</h4>
                        <p class="subtitle-ecumex">TODO EMPIEZA AQUÍ</p>
                    </div>
                </div>
                <div class="modal-body">
                    <form asp-controller="Account" asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="label-ecumex">USUARIO / CORREO</label>
                            <input type="email" name="Email" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="label-ecumex">CONTRASEÑA</label>
                            <input type="password" name="Password" class="form-control" required />
                        </div>
                        <button type="submit" class="btn-login-ecumex">INGRESAR AL SISTEMA</button>
                    </form>
                    <div class="register-container-ecumex">
                        <p class="register-text-ecumex">¿AÚN NO TIENES CUENTA?</p>
                        <!-- Redirección corregida al controlador de registro -->
                        <a asp-controller="Account" asp-action="Register" class="link-register-ecumex">REGÍSTRATE AQUÍ →</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>