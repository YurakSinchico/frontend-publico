<div class="d-flex flex-column h-100 p-3 text-white">
    <!-- Logo o Título del Sidebar -->
    <div class="text-center mb-4 pb-2 border-bottom border-secondary">
        <h5 class="fw-bold text-warning m-0">⚡ UTN GOL</h5>
    </div>

    <!-- Links de navegación verticales -->
    <ul class="nav nav-pills flex-column mb-auto">
        <li class="nav-item mb-1">
            <a asp-controller="Home" asp-action="Index" class="nav-link text-white">
                <i class="bi bi-house-door me-2"></i> Inicio
            </a>
        </li>
        <li class="mb-1">
            <a asp-controller="Partidos" asp-action="Index" class="nav-link text-white">
                <i class="bi bi-calendar-event me-2"></i> Calendario
            </a>
        </li>
        <li class="mb-1">
            <a asp-controller="Estadisticas" asp-action="Index" class="nav-link text-white">
                <i class="bi bi-graph-up me-2"></i> Estadísticas
            </a>
        </li>
        <li class="mb-1">
            <a asp-controller="Grupos" asp-action="Index" class="nav-link text-white">
                <i class="bi bi-grid-3x3-gap me-2"></i> Grupos
            </a>
        </li>
        <li class="mb-1">
            <a asp-controller="Dashboard" asp-action="Index" class="nav-link text-white">
                <i class="bi bi-speedometer2 me-2"></i> Mi Panel
            </a>
        </li>
    </ul>

    <!-- Bloque de usuario al fondo de la barra lateral -->
    <div class="mt-auto border-top border-secondary pt-3">
        @if (User.Identity.IsAuthenticated)
        {
            <div class="d-flex align-items-center mb-3 px-2">
                <i class="bi bi-person-circle fs-3 text-warning me-2"></i>
                <div class="text-truncate" style="max-width: 150px;">
                    <div class="small fw-bold text-white">Usuario</div>
                    <div class="text-muted" style="font-size: 11px;">@User.Identity.Name</div>
                </div>
            </div>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger w-100 btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i> Cerrar Sesión
            </a>
        }
    </div>
</div>