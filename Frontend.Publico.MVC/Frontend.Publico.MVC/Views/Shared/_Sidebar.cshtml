@using Microsoft.AspNetCore.Http

@{
    bool isAuth = User.Identity?.IsAuthenticated == true;
    var nombreUsuario = isAuth
        ? (!string.IsNullOrEmpty(User.Identity?.Name) ? User.Identity.Name : (Context.Session.GetString("Nombre") ?? "Usuario"))
        : "Invitado";
    var emailUsuario = isAuth
        ? (Context.Session.GetString("Email") ?? "usuario@utngol.com")
        : "invitado@utngol.com";
}

<div class="sidebar-container">

    <!-- Logo Mundialista -->
    <div class="sidebar-logo">
        <div class="logo-icon-badge">
            <i class="bi bi-dribbble"></i>
        </div>
        <div class="logo-text-box">
            <h4>UTN <span class="text-cyan">GolMundial</span></h4>
            <span>2026 • USA-MEX-CAN</span>
        </div>
    </div>

    <!-- Perfil del Usuario -->
    <div class="sidebar-user-card">
        <div class="user-avatar-glow">
            <i class="bi bi-person-fill"></i>
        </div>
        <div class="user-details">
            <h6 class="user-name">@nombreUsuario</h6>
            <small class="user-email">@emailUsuario</small>
        </div>
    </div>

    <!-- Menú de Navegación -->
    <div class="sidebar-menu-wrapper">
        <span class="menu-header-label">MENÚ PRINCIPAL</span>
        <ul class="sidebar-menu">
            <li>
                <a asp-controller="Dashboard" asp-action="Index" class="nav-item-link">
                    <i class="bi bi-house-door-fill"></i>
                    <span>Inicio / Dashboard</span>
                </a>
            </li>

            <li>
                <a asp-controller="Partidos" asp-action="Index" class="nav-item-link">
                    <i class="bi bi-calendar-event-fill"></i>
                    <span>Calendario Partidos</span>
                </a>
            </li>

            <li>
                <a asp-controller="Grupos" asp-action="Index" class="nav-item-link">
                    <i class="bi bi-layers-fill"></i>
                    <span>Tablas de Posiciones</span>
                </a>
            </li>

            <li>
                <a asp-controller="Estadisticas" asp-action="Index" class="nav-item-link">
                    <i class="bi bi-bar-chart-line-fill"></i>
                    <span>Estadísticas</span>
                </a>
            </li>

            <li>
                <a asp-controller="Selecciones" asp-action="Index" class="nav-item-link">
                    <i class="bi bi-flag-fill"></i>
                    <span>Selecciones</span>
                </a>
            </li>

            <li>
                <a asp-controller="Predicciones" asp-action="Index" class="nav-item-link">
                    <i class="bi bi-magic"></i>
                    <span>Mis Predicciones</span>
                </a>
            </li>

            <li>
                <a asp-controller="Billetera" asp-action="Index" class="nav-item-link">
                    <i class="bi bi-wallet2"></i>
                    <span>Billetera UTNGolCoin</span>
                </a>
            </li>

            <li>
                <a asp-controller="Ranking" asp-action="Index" class="nav-item-link">
                    <i class="bi bi-trophy-fill text-warning"></i>
                    <span>Ranking Global</span>
                </a>
            </li>

            <li>
                <a asp-controller="Home" asp-action="Index" class="nav-item-link">
                    <i class="bi bi-globe"></i>
                    <span>Inicio Público</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- Footer Logout / Login -->
    <div class="sidebar-footer">
        @if (isAuth)
        {
            <a asp-controller="Account"
               asp-action="Logout"
               class="logout-btn">
                <i class="bi bi-box-arrow-right"></i>
                <span>Cerrar Sesión</span>
            </a>
        }
        else
        {
            <button class="logout-btn sidebar-login-btn" data-bs-toggle="modal" data-bs-target="#loginModal">
                <i class="bi bi-box-arrow-in-right"></i>
                <span>Iniciar Sesión</span>
            </button>
        }
    </div>

</div>

